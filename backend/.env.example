# Application
APP_NAME=koperasi-api
APP_PORT=8080
APP_ENV=development

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=koperasi
DB_SSL_MODE=disable

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=koperasi-api

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRATION_HOURS=24
JWT_REFRESH_HOURS=168

# S3-Compatible Storage
STORAGE_ENDPOINT=
STORAGE_BUCKET=koperasi
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_REGION=us-east-1
