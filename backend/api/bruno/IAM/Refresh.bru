meta {
  name: Refresh Token
  type: http
  seq: 4
}

post {
  url: {{base_url}}/auth/refresh
  body: json
  auth: none
}

body:json {
  {
    "refresh_token": "{{refresh_token}}"
  }
}

script:post-response {
  if (res.status === 200) {
    bru.setEnvVar("token", res.body.data.access_token);
    bru.setEnvVar("refresh_token", res.body.data.refresh_token);
  }
}
